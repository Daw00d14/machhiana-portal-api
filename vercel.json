{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "machh/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/machh/(.*)", "dest": "/machh/$1" },
    { "src": "/machh", "dest": "/machh/index.html" },
    { "src": "/import", "dest": "/import.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
